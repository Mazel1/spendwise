# ─────────────────────────────────────────────────────────────────────────────
# SpendWise — Environment Variables
# Copy this file to .env and fill in the values before starting the project.
#
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── App ───────────────────────────────────────────────────────────────────────

APP_ENV=production
# Set to "development" locally to enable /docs and verbose logging

DEBUG=false
# Never set to true in production

SECRET_KEY=replace-with-a-long-random-string-minimum-32-chars
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"


# ── Database ──────────────────────────────────────────────────────────────────

POSTGRES_USER=spendwise
POSTGRES_PASSWORD=replace-with-a-strong-db-password
POSTGRES_DB=spendwise

# Used by the backend (asyncpg driver). Points to the db service in Docker.
DATABASE_URL=postgresql+asyncpg://spendwise:replace-with-a-strong-db-password@db:5432/spendwise


# ── CORS ──────────────────────────────────────────────────────────────────────

# Exact origin of your frontend — no trailing slash
# Local:      ["http://localhost:3000"]
# Production: ["https://your-app-domain.com"]
ALLOWED_ORIGINS=["http://localhost:3000"]


# ── AI Categorization & Insights ──────────────────────────────────────────────

# Provider: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Get your key at https://console.anthropic.com or https://platform.openai.com
# Leave empty to disable AI features (expenses will default to category "Other")
LLM_API_KEY=

# Model to use — must match the selected provider
# Anthropic: claude-sonnet-4-20250514  (recommended), claude-haiku-4-5-20251001 (cheaper)
# OpenAI:    gpt-4o-mini               (recommended), gpt-4o
LLM_MODEL=claude-sonnet-4-20250514


# ── JWT Auth ──────────────────────────────────────────────────────────────────

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
# 10080 = 7 days. Reduce for higher security (e.g. 1440 = 1 day)


# ── Frontend ──────────────────────────────────────────────────────────────────

# The public URL of the backend API — used by the Next.js app at build time
# Local:      http://localhost:8000
# Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000
